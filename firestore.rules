rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, role, createdAt
    //
    // Collection: reports
    // Fields: id, authorUid, content, sentiment, dominantEmotion, aiInsights, createdAt
    //
    // Collection: uploads
    // Fields: id, uploaderUid, fileName, fileType, fileSize, recordCount, status, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "devanshmittal080@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'analyst', 'user'];
    }

    function isValidReport(data) {
      return data.keys().hasAll(['authorUid', 'content', 'createdAt']) &&
             data.authorUid == request.auth.uid &&
             data.content is string && data.content.size() < 10000;
    }

    function isValidUpload(data) {
      return data.keys().hasAll(['uploaderUid', 'fileName', 'status', 'createdAt']) &&
             data.uploaderUid == request.auth.uid &&
             data.fileName is string && data.fileName.size() < 255 &&
             data.status in ['pending', 'processing', 'completed', 'failed'];
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));
    }

    match /reports/{reportId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidReport(request.resource.data);
      allow update: if isAuthenticated() && isValidReport(request.resource.data) && resource.data.authorUid == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin());
    }

    match /uploads/{uploadId} {
      allow read: if isAuthenticated() && (resource.data.uploaderUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidUpload(request.resource.data);
      allow update: if isAuthenticated() && isValidUpload(request.resource.data) && resource.data.uploaderUid == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.uploaderUid == request.auth.uid || isAdmin());
    }
  }
}
